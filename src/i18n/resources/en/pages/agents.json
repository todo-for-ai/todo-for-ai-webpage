          "label": "Sandbox Profile",
          "tooltip": "Security isolation level for code execution",
          "options": {
            "strict": "Strict Isolation (nsjail)",
            "standard": "Standard (RestrictedPython)",
            "permissive": "Permissive (Basic)"
          },
          "descriptions": {
            "strict": "Full system isolation using nsjail. Blocks all system calls except whitelisted ones. Recommended for untrusted code.",
            "standard": "Python-level restrictions using RestrictedPython. Prevents dangerous Python operations while maintaining performance.",
            "permissive": "Minimal isolation. Only basic resource limits applied. Suitable for trusted internal scripts."
          }
        },

            "whitelist": "Whitelist Mode",
            "isolated": "Complete Isolation",
            "full": "Full Access"
          },
          "descriptions": {
            "whitelist": "Only allows connections to explicitly listed domains. Most secure option.",
            "isolated": "Blocks all network access. Code cannot make any external connections.",
            "full": "Unrestricted network access. Use with caution."
          }
